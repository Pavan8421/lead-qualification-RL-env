# Copy to .env and fill in values (see docs/PHASE0_PREREQUISITES.md)
# cp .env.example .env

# --- Hackathon / inference (inference.py, OpenAI-compatible API) ---
OPENAI_API_KEY=
API_BASE_URL=https://api.openai.com/v1
MODEL_NAME=gpt-4o-mini

# --- Hugging Face (Spaces deploy, Hub, optional client pulls) ---
HF_TOKEN=

# --- Optional: connect baseline to a running env (override in code if unused) ---
# LEAD_TRIAGE_ENV_BASE_URL=http://localhost:8000

# --- OpenEnv server (lead_triage_env / uvicorn) ---
HOST=0.0.0.0
PORT=8000
